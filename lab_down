#!/usr/bin/env bash

set -e

echo "===================================="
echo "Enhanced CPU AI Lab Shutdown Script"
echo "===================================="

# ⚡ Usage Examples
#
# Standard shutdown (keeps data and volumes):
#
#   ./lab_down
#
# Deep clean (remove containers, volumes, networks, and images):
#
#   ./lab_down --clean
#
# Verify all containers are stopped:
#
#   docker ps

# -------------------------------
# Step 0: Parse optional flags
# -------------------------------

CLEAN=false

while [[ "$#" -gt 0 ]]; do
case $1 in
--clean) CLEAN=true ;;
*) echo "Unknown option: $1"; exit 1 ;;
esac
shift
done

# -------------------------------
# Step 1: Stop any background lab scripts
# -------------------------------

echo "Stopping any lab watcher scripts..."
pkill -f lab_up || true
pkill -f docker-compose || true

# -------------------------------
# Step 2: Stop docker compose stack
# -------------------------------

echo "Stopping docker compose services..."
docker compose down --remove-orphans || true

# -------------------------------
# Step 3: Disable restart policies
# -------------------------------

echo "Disabling restart policies for all containers..."
for c in $(docker ps -aq); do
docker update --restart=no $c >/dev/null 2>&1 || true
done

# -------------------------------
# Step 4: Stop any remaining running containers
# -------------------------------

echo "Stopping remaining containers..."
docker stop $(docker ps -q) >/dev/null 2>&1 || true

# -------------------------------
# Step 5: Remove all containers
# -------------------------------

echo "Removing all containers..."
docker rm $(docker ps -aq) >/dev/null 2>&1 || true

# -------------------------------
# Step 6: Remove unused networks
# -------------------------------

echo "Cleaning up unused networks..."
docker network prune -f >/dev/null 2>&1 || true

# -------------------------------
# Step 7: Optional deep clean
# -------------------------------

if [[ $CLEAN == true ]]; then
echo "Performing deep clean: removing volumes and unused images..."
docker volume prune -f >/dev/null 2>&1 || true
docker system prune -af >/dev/null 2>&1 || true
fi

# -------------------------------
# Step 8: Status report
# -------------------------------

echo "===================================="
echo "CPU AI Lab shutdown complete."
docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
echo "All services stopped. No containers should be running."
echo "===================================="

