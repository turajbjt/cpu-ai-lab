i#!/bin/bash
# ./lab - CPU AI Lab robust startup script

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}🟢 Preparing CPU AI Lab environment...${NC}"

# --- CLI flags ---
NO_LOGS=false
FAST_START=false
for arg in "$@"; do
    case $arg in
        --no-logs) NO_LOGS=true ;;
        --fast-start) FAST_START=true ;;
        *) echo -e "${YELLOW}⚠️ Unknown option: $arg${NC}" ;;
    esac
done

# --- Utility functions ---
safe_remove_container() {
    local name="$1"
    if docker ps -a --format '{{.Names}}' | grep -q "^${name}$"; then
        echo -e "${YELLOW}🛠 Removing existing container: $name${NC}"
        docker rm -f "$name"
    fi
}

safe_remove_volume() {
    local name="$1"
    if docker volume ls --format '{{.Name}}' | grep -q "^${name}$"; then
        echo -e "${YELLOW}🛠 Removing existing volume: $name${NC}"
        docker volume rm "$name"
    fi
}

safe_remove_network() {
    local name="$1"
    if docker network ls --format '{{.Name}}' | grep -q "^${name}$"; then
        echo -e "${YELLOW}🛠 Removing existing network: $name${NC}"
        docker network rm "$name"
    fi
}

stream_container_logs() {
    local name="$1"
    echo -e "${BLUE}📖 Streaming logs for $name...${NC}"
    docker logs -f "$name" 2>&1 | sed "s/^/[$name] /"
}

wait_for_service() {
    local name="$1"
    local url="$2"
    echo -e "${BLUE}⏳ Waiting for $name to respond at $url...${NC}"
    until curl -s -f "$url" >/dev/null 2>&1; do
        sleep 2
    done
    echo -e "${GREEN}✅ $name is ready!${NC}"
}

wait_for_ollama_models() {
    local expected_models=("phi3" "mistral" "codellama" "nomic-embed-text")
    echo -e "${BLUE}⏳ Waiting for Ollama models to be available...${NC}"
    until curl -s http://localhost:11434/v1/models | grep -E "$(IFS='|'; echo "${expected_models[*]}")" >/dev/null; do
        sleep 2
    done
    echo -e "${GREEN}✅ All Ollama models are ready!${NC}"
}

# --- Cleanup ---
echo -e "${BLUE}🔄 Cleaning previous containers, volumes, and network...${NC}"
for c in ollama bootstrap_models openwebui flowise qdrant n8n; do
    safe_remove_container "$c"
done

for v in ollama openwebui flowise qdrant n8n; do
    safe_remove_volume "$v"
done

safe_remove_network "cpu-ai-lab_default"

# --- Pull/build images ---
echo -e "${BLUE}📦 Pulling/building Docker images...${NC}"
docker pull ollama/ollama:latest
docker pull ghcr.io/open-webui/open-webui:main
docker pull flowiseai/flowise
docker pull qdrant/qdrant
docker pull n8nio/n8n

# --- Start containers ---
echo -e "${BLUE}🟢 Starting CPU AI Lab containers...${NC}"
docker-compose up -d --build

# --- Optionally stream logs ---
if [ "$NO_LOGS" = false ]; then
    for c in ollama bootstrap_models openwebui flowise qdrant n8n; do
        stream_container_logs "$c" &
    done
fi

# --- Health checks ---
if [ "$FAST_START" = false ]; then
    wait_for_service "Ollama" "http://localhost:11434/v1/models"
    wait_for_ollama_models
    wait_for_service "OpenWebUI" "http://localhost:3000"
    wait_for_service "Flowise" "http://localhost:3001"
    wait_for_service "N8N" "http://localhost:5678"
    wait_for_service "Qdrant" "http://localhost:6333/collections"
    echo -e "${GREEN}🎉 CPU AI Lab is fully ready! All services are running and responsive.${NC}"
else
    echo -e "${YELLOW}⚡ Fast start enabled, skipping health checks. Containers are running.${NC}"
fi

# --- Wait for logs if enabled ---
if [ "$NO_LOGS" = false ]; then
    wait
fi
