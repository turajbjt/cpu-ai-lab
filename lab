#!/bin/bash
# cpu-ai-lab.sh — unified CPU AI Lab management script
# Fully automated: waits for Qdrant and WebUI, works with Docker Compose v2+

LAB_DIR="$(dirname "$0")"
COMPOSE_FILE="$LAB_DIR/docker-compose.yml"
WEBUI_PORT=3005
QDRANT_PORT=6333
MAX_WAIT=60  # seconds

# How to run
# Reset everything and build locally
#  ./cpu-ai-lab.sh reset
#
# Start containers
#  ./cpu-ai-lab.sh up
#
# Stop containers
#  ./cpu-ai-lab.sh down
#
# Check container status
#  ./cpu-ai-lab.sh status
#
# Tail logs
#  ./cpu-ai-lab.sh logs

usage() {
    echo "Usage: $0 {up|down|reset|status|logs}"
    echo "  up      - Start all containers and wait for Qdrant & WebUI"
    echo "  down    - Stop all containers"
    echo "  reset   - Stop, remove, rebuild containers, wait for Qdrant & WebUI"
    echo "  status  - Show running containers"
    echo "  logs    - Tail logs of all containers"
    exit 1
}

wait_for_qdrant_http() {
    echo "Waiting for Qdrant to respond on port $QDRANT_PORT..."
    for ((i=0; i<MAX_WAIT; i++)); do
        if curl -s "http://localhost:$QDRANT_PORT/collections" >/dev/null; then
            echo "Qdrant is responding!"
            return 0
        fi
        echo -n "."
        sleep 1
    done
    echo
    echo "Warning: Qdrant did not respond after $MAX_WAIT seconds."
}

wait_for_webui() {
    echo "Waiting for WebUI to respond on port $WEBUI_PORT..."
    for ((i=0; i<MAX_WAIT; i++)); do
        if curl -s "http://localhost:$WEBUI_PORT" >/dev/null; then
            echo "WebUI is ready at http://localhost:$WEBUI_PORT"
            return 0
        fi
        echo -n "."
        sleep 1
    done
    echo
    echo "Warning: WebUI did not respond after $MAX_WAIT seconds."
}

if [ $# -lt 1 ]; then
    usage
fi

ACTION="$1"

case "$ACTION" in
    up)
        echo "Starting CPU AI Lab containers..."
        docker compose -f "$COMPOSE_FILE" up -d
        wait_for_qdrant_http
        wait_for_webui
        ;;
    down)
        echo "Stopping CPU AI Lab containers..."
        docker compose -f "$COMPOSE_FILE" down
        ;;
    reset)
        echo "Resetting CPU AI Lab..."
        docker compose -f "$COMPOSE_FILE" down
        docker compose -f "$COMPOSE_FILE" rm -f
        docker compose -f "$COMPOSE_FILE" build --no-cache
        docker compose -f "$COMPOSE_FILE" up -d
        wait_for_qdrant_http
        wait_for_webui
        ;;
    status)
        echo "Listing CPU AI Lab containers..."
        docker ps --format "table {{.Names}}\t{{.Image}}\t{{.Status}}\t{{.Ports}}"
        ;;
    logs)
        echo "Tailing logs of all CPU AI Lab containers..."
        docker compose -f "$COMPOSE_FILE" logs -f
        ;;
    *)
        usage
        ;;
esac

