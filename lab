#!/bin/bash
# ./lab - CPU AI Lab release-ready startup script

# --- Color codes ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${BLUE}🟢 Preparing CPU AI Lab environment...${NC}"

# --- CLI flags ---
NO_LOGS=false
FAST_START=false

for arg in "$@"; do
    case $arg in
        --no-logs) NO_LOGS=true ;;
        --fast-start) FAST_START=true ;;
        *) echo -e "${YELLOW}⚠️ Unknown option: $arg${NC}" ;;
    esac
done

# --- Utility functions ---
safe_remove_container() {
    local name="$1"
    if docker ps -a --format '{{.Names}}' | grep -q "^${name}$"; then
        echo -e "${YELLOW}🛠 Removing existing container: $name${NC}"
        docker rm -f "$name"
    else
        echo -e "${GREEN}✅ No existing container named $name${NC}"
    fi
}

safe_remove_volume() {
    local name="$1"
    if docker volume ls --format '{{.Name}}' | grep -q "^${name}$"; then
        echo -e "${YELLOW}🛠 Removing existing volume: $name${NC}"
        docker volume rm "$name"
    else
        echo -e "${GREEN}✅ No existing volume named $name${NC}"
    fi
}

safe_remove_network() {
    local name="$1"
    if docker network ls --format '{{.Name}}' | grep -q "^${name}$"; then
        echo -e "${YELLOW}🛠 Removing existing network: $name${NC}"
        docker network rm "$name"
    else
        echo -e "${GREEN}✅ No existing network named $name${NC}"
    fi
}

stream_container_logs() {
    local name="$1"
    echo -e "${BLUE}📖 Streaming logs for $name...${NC}"
    docker logs -f "$name" 2>&1 | sed "s/^/[$name] /"
}

wait_for_http() {
    local name="$1"
    local url="$2"
    echo -e "${BLUE}⏳ Waiting for $name to respond at $url...${NC}"
    until curl -s -o /dev/null "$url"; do
        sleep 2
    done
    echo -e "${GREEN}✅ $name is responding!${NC}"
}

wait_for_ollama() {
    local host="localhost"
    local port="11434"
    echo -e "${BLUE}⏳ Waiting for Ollama model server on $host:$port...${NC}"
    until curl -s "http://$host:$port/v1/models" >/dev/null 2>&1; do
        sleep 2
    done
    echo -e "${GREEN}✅ Ollama model server is ready!${NC}"
}

wait_for_qdrant() {
    local host="localhost"
    local port="6333"
    echo -e "${BLUE}⏳ Waiting for Qdrant on $host:$port...${NC}"
    until curl -s "http://$host:$port/collections" >/dev/null 2>&1; do
        sleep 2
    done
    echo -e "${GREEN}✅ Qdrant is ready!${NC}"
}

# --- Cleanup previous resources ---
echo -e "${BLUE}🔄 Cleaning previous containers, volumes, and network...${NC}"
safe_remove_container "ollama"
safe_remove_container "multi_agent_webui"
safe_remove_container "n8n"
safe_remove_container "qdrant"
safe_remove_container "openwebui"

safe_remove_volume "cpu-ai-lab_ollama"
safe_remove_volume "cpu-ai-lab_n8n"
safe_remove_volume "cpu-ai-lab_qdrant"
safe_remove_volume "cpu-ai-lab_flowise"
safe_remove_volume "cpu-ai-lab_openwebui"

safe_remove_network "cpu-ai-lab_default"

# --- Pull/build Docker images ---
echo -e "${BLUE}📦 Pulling/building Docker images...${NC}"
docker pull flowiseai/flowise:latest
docker build -t cpu-ai-lab-agents ./agents
docker build -t cpu-ai-lab-webui ./webui

# --- Start containers ---
echo -e "${BLUE}🟢 Starting CPU AI Lab containers...${NC}"
docker-compose up -d --build

# --- Optionally stream logs ---
if [ "$NO_LOGS" = false ]; then
    containers=("ollama" "multi_agent_webui" "n8n" "qdrant" "openwebui")
    for c in "${containers[@]}"; do
        stream_container_logs "$c" &
    done
fi

# --- Health checks ---
if [ "$FAST_START" = false ]; then
    wait_for_http "OpenWebUI" "http://localhost:5000"
    wait_for_http "Flowise" "http://localhost:3000"
    wait_for_http "N8N" "http://localhost:5678"
    wait_for_ollama
    wait_for_qdrant
    echo -e "${GREEN}🎉 CPU AI Lab is fully ready! All services are running and responsive.${NC}"
else
    echo -e "${YELLOW}⚡ Fast start enabled, skipping health checks. Containers are running.${NC}"
fi

# --- Wait for background logs if any ---
if [ "$NO_LOGS" = false ]; then
    wait
fi
